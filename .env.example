# Quant Lab local deployment template.
# Copy this file to .env before running Docker Compose.

# Backend persistence
QUANT_LAB_DB_PATH=/app/data/quant_lab.sqlite3
QUANT_LAB_DUCKDB_PATH=/app/data/quant_lab.duckdb
QUANT_LAB_CANDLE_PARQUET_PATH=/app/data/quant_lab_market_candles.parquet
QUANT_LAB_COLUMNAR_CACHE_ENABLED=true
QUANT_LAB_CANDLE_CACHE_TTL_SECONDS=300

# Background scans
QUANT_LAB_RESEARCH_SCHEDULER_ENABLED=true
QUANT_LAB_RESEARCH_SCHEDULER_POLL_SECONDS=60

# Upbit public/private configuration
UPBIT_BASE_URL=https://api.upbit.com
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Live trading must stay disabled until a separately approved cutover window.
QUANT_LAB_LIVE_TRADING_ENABLED=false
QUANT_LAB_LIVE_TRADING_ACK=
QUANT_LAB_MIN_ORDER_NOTIONAL_KRW=5000
QUANT_LAB_APPROVAL_FEE_BPS=5
QUANT_LAB_MAX_APPROVAL_EXPOSURE_PCT=60

# Optional stock/ETF daily data
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co

# Optional Alpaca paper trading.
# Keep disabled unless testing the credential-gated paper adapter.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_TRADING_ENABLED=false
ALPACA_PAPER_TRADING_ACK=
